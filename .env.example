# SupplyScout — Environment Variables
# Copy this to .env and fill in your actual keys
# NEVER commit .env to git

# ─── BillOfLadingData.com ───────────────────────────────────────────────────
BOL_API_KEY=your_bol_api_key_here
BOL_API_BASE_URL=https://api.billofladingdata.com

# ─── Supabase ────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your_supabase_anon_key
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# ─── Companies House UK ──────────────────────────────────────────────────────
# Register free at: https://developer.company-information.service.gov.uk
COMPANIES_HOUSE_API_KEY=your_companies_house_api_key

# ─── OpenCorporates ───────────────────────────────────────────────────────────
# Free tier: 500 req/day — https://opencorporates.com/api_accounts/new
OPENCORPORATES_API_KEY=your_opencorporates_api_key

# ─── Stripe ──────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_secret
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_your_publishable_key

# ─── Next.js Public ──────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Apify (ImportYeti scraper — free-tier BOL testing) ──────────────────────
# Register at: https://console.apify.com — free tier ~$5/month credit
# Find actor ID at: https://apify.com/store (search "importyeti")
APIFY_API_TOKEN=apify_api_your_token_here
APIFY_IMPORTYETI_ACTOR_ID=epctex/importyeti-scraper

# ─── Dev Flags ───────────────────────────────────────────────────────────────
# Set to "true" to use mock BOL data instead of real API calls
USE_MOCK_BOL=true
# Set to "apify" to use Apify/ImportYeti instead of BillOfLadingData.com
BOL_DATA_SOURCE=apify

# ─── Rate Limiting ───────────────────────────────────────────────────────────
# Max retries for API calls with exponential backoff
MAX_RETRIES=3
RETRY_DELAY_MS=1000
